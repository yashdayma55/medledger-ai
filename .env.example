# Supabase (from project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (for OTP / password reset) - https://resend.com
# With unverified @resend.dev, you can only send TO your own account email.
# Set RESEND_DEV_OVERRIDE_TO to that email so all test emails go to your inbox.
# For production: verify a domain at resend.com/domains and use a from address on that domain.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=MedLedger <onboarding@resend.dev>
RESEND_DEV_OVERRIDE_TO=your-verified-email@example.com

# Resend – second sender (use when sending to this address)
RESEND_SECONDARY_EMAIL=second-allowed@example.com
RESEND_API_KEY_2=re_yyyyyyyyyyyy
RESEND_FROM_EMAIL_2=MedLedger <onboarding2@resend.dev>

# Resend – third sender
RESEND_TERTIARY_EMAIL=third-allowed@example.com
RESEND_API_KEY_3=re_zzzzzzzzzzzz
RESEND_FROM_EMAIL_3=MedLedger <onboarding3@resend.dev>

# Resend – fourth sender
RESEND_QUATERNARY_EMAIL=fourth-allowed@example.com
RESEND_API_KEY_4=re_wwwwwwwwwwww
RESEND_FROM_EMAIL_4=MedLedger <onboarding4@resend.dev>

# OpenAI (for PDF parsing / Create medical record – Parse from PDF)
# Prefer this if you have a direct OpenAI API key (platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key

# Azure OpenAI (alternative – from Azure Portal: your OpenAI resource → Keys and Endpoint)
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# AZURE_OPENAI_RESOURCE_NAME=your-resource-name
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Gemini (fallback if OPENAI_API_KEY is not set – free tier has strict limits)
# GEMINI_API_KEY=your-gemini-api-key

# Session (JWT cookie) - use a long random string in production
SESSION_SECRET=your-session-secret-min-32-chars

# App URL (for password reset links) - e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
